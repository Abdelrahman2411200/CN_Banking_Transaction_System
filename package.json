{
  "name": "cn-banking-transaction-system",
  "version": "1.0.0",
  "private": true,
  "description": "CN Banking Transaction System - Microservices Architecture",
  "workspaces": [
    "shared/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern=\"__tests__\" --forceExit",
    "test:integration": "jest --testPathPattern=\"tests/integration\" --forceExit",
    "lint": "eslint . --ext .ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  }
}
