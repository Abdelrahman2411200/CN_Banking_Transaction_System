{
  "name": "cn-banking-transaction-system",
  "version": "1.0.0",
  "private": true,
  "description": "CN Banking Transaction System - Microservices Architecture",
  "workspaces": [
    "shared/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:images": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validate-service-images.ps1",
    "test:containers": "node --test tests/container/dockerfile-policy.test.mjs",
    "dev": "npm run -ws dev",
    "lint": "npm run -ws lint",
    "typecheck": "npm run -ws typecheck",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern=\"__tests__\" --forceExit",
    "test:integration": "jest --testPathPattern=\"tests/integration\" --runInBand --forceExit",
    "test:integration:sam": "node --test tests/integration/health.test.mjs tests/integration/api-contract.test.mjs tests/integration/db-schema.test.mjs",
    "test:all": "npm run test && npm run test:integration:sam"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.10",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "pg": "^8.16.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0"
  }
}
