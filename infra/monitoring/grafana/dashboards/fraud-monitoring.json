{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "uid": "fraud-monitoring-v1",
  "title": "Fraud Monitoring",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "piechart",
      "title": "Alerts by Severity",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "sum by(severity) (fraud_alerts_triggered_total)", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Alerts Over Time by Severity",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "sum by(severity) (rate(fraud_alerts_triggered_total[5m]))", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Rule Trigger Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "sum by(rule_name) (rate(fraud_rules_evaluated_total[5m]))", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Fraud Evaluation Latency P99",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(fraud_evaluation_duration_ms_bucket[5m])) by (le))", "refId": "A" }]
    }
  ]
}
